<Window x:Class="SnapText.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="SnapText" Height="650" Width="850" MinHeight="600" MinWidth="750"
        WindowStyle="None" ResizeMode="CanResizeWithGrip"
        AllowsTransparency="False"
        Background="#08080C"
        Foreground="#E0E0E0"
        TextElement.Foreground="#E0E0E0"
        Icon="Assets/logo.png"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Glassmorphism Card Style -->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.5" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <SolidColorBrush x:Key="iosBlue" Color="#0A84FF"/>
        <SolidColorBrush x:Key="iosRed" Color="#FF453A"/>
        <SolidColorBrush x:Key="iosTextSecondary" Color="#8E8E93"/>

        <!-- Premium Pill Button -->
        <Style x:Key="iosPillButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource iosBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="iosIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="50" GlassFrameThickness="0" CornerRadius="0" ResizeBorderThickness="8"/>
    </shell:WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid" Background="#08080C">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/> <!-- Left: History -->
            <ColumnDefinition Width="*"/>   <!-- Right: Main Viewer -->
        </Grid.ColumnDefinitions>

        <!-- ========== LEFT PANEL: HISTORY ========== -->
        <Border Grid.Column="0" Background="#0D0D0F" BorderBrush="#1AFFFFFF" BorderThickness="0,0,1,0">
            <Grid Margin="20,25,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ÇALIŞMA GEÇMİŞİ" FontSize="11" FontWeight="Bold" Foreground="{StaticResource iosTextSecondary}" Margin="0,0,0,25" />

                <ListBox Grid.Row="1" x:Name="HistoryListBox" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="HistoryListBox_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Margin" Value="0,0,0,12"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd" CornerRadius="14" Background="{TemplateBinding Background}" Padding="15,12" BorderThickness="1" BorderBrush="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#1AFFFFFF"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#20FFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#08FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding Text}" FontSize="13" Foreground="#DDD" MaxHeight="38" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Timestamp, StringFormat='dd MMM, HH:mm'}" FontSize="10" Foreground="#666" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Button x:Name="PinBtn" Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="0" Width="24" Height="24" VerticalAlignment="Center" Click="TogglePin_Click" Tag="{Binding}" Margin="0,0,4,0">
                                    <materialDesign:PackIcon x:Name="PinIcon" Kind="PinOutline" Width="14" Height="14" Foreground="#666"/>
                                </Button>
                                <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="0" Width="24" Height="24" VerticalAlignment="Center" Click="DeleteHistoryItem_Click" Tag="{Binding}" ToolTip="Sil">
                                    <materialDesign:PackIcon Kind="DeleteOutline" Width="14" Height="14" Foreground="#FF453A"/>
                                </Button>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                    <Setter TargetName="PinIcon" Property="Kind" Value="Pin"/>
                                    <Setter TargetName="PinIcon" Property="Foreground" Value="{StaticResource iosBlue}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="2" Content="Sabitlenmeyenleri Sil" Margin="0,15,0,0" Click="ClearHistory_Click" Foreground="{StaticResource iosRed}" Background="Transparent" BorderThickness="0" FontWeight="SemiBold" FontSize="13"/>
            </Grid>
        </Border>

        <!-- ========== RIGHT PANEL: EDITOR ========== -->
        <Grid Grid.Column="1" Margin="30,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Text Editor -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Navigation Header -->
            <Grid Grid.Row="0" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="10" Background="{StaticResource iosBlue}" Margin="0,0,15,0">
                        <TextBlock Text="S" FontWeight="Black" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="SnapText" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource iosIconButton}" Click="OpenDrawer_Click" Margin="0,0,10,0">
                        <materialDesign:PackIcon Kind="Settings" Width="22" Height="22" Opacity="0.8" Foreground="White"/>
                    </Button>
                    <Button Style="{StaticResource iosIconButton}" Click="CloseButton_Click">
                        <materialDesign:PackIcon Kind="Close" Width="22" Height="22" Foreground="{StaticResource iosRed}"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Central Text Editor Card -->
            <Border Grid.Row="1" Style="{StaticResource GlassCard}" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Workspace Toolbar -->
                    <Border Grid.Row="0" Background="#08FFFFFF" CornerRadius="20,20,0,0" Padding="15,10">
                        <Grid>
                            <TextBlock Text="KOPYALANAN METİN" Opacity="0.4" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource iosIconButton}" Click="CopyCurrent_Click" ToolTip="Panoya Kopyala" Width="32" Height="32">
                                    <materialDesign:PackIcon Kind="ContentCopy" Width="16"/>
                                </Button>
                                <Button Style="{StaticResource iosIconButton}" Click="ClearCurrent_Click" Foreground="{StaticResource iosRed}" ToolTip="İçeriği Sil" Width="32" Height="32">
                                    <materialDesign:PackIcon Kind="DeleteSweep" Width="16"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Main Text Output -->
                    <TextBox Grid.Row="1" x:Name="ResultTextBox" Background="Transparent" BorderThickness="0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" 
                             FontSize="17" Foreground="#F2F2F7" CaretBrush="{StaticResource iosBlue}" Padding="25"
                             FontFamily="Segoe UI Variable Text, Segoe UI, sans-serif"/>
                </Grid>
            </Border>

            <!-- Capture Button -->
            <Border Grid.Row="2" Background="#1AFFFFFF" CornerRadius="25" BorderBrush="#25FFFFFF" BorderThickness="1" Padding="6" Height="54">
                <Button ToolTip="Yeni Ekran Yakala" Style="{StaticResource iosIconButton}" Click="CaptureButton_Click" 
                        Background="#200A84FF" Foreground="{StaticResource iosBlue}" HorizontalAlignment="Stretch" Margin="0" Height="40" Width="Auto">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="CameraPlus" Width="20" Height="20" VerticalAlignment="Center"/>
                        <TextBlock Text="Yeni Tarama Yap" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Border>
        </Grid>

        <!-- ========== OVERLAYS / MODALS ========== -->
        
        <!-- Settings Overlay -->
        <Grid Grid.ColumnSpan="2" x:Name="SettingsOverlay" Visibility="Collapsed" Panel.ZIndex="50">
            <Border Background="#66000000" MouseDown="CloseDrawer_Click">
                <Border.Effect>
                    <BlurEffect Radius="10"/>
                </Border.Effect>
            </Border>
            <Border HorizontalAlignment="Right" Width="400" Background="#111113" BorderBrush="#1AFFFFFF" BorderThickness="1,0,0,0">
                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Konfigürasyon" FontWeight="Black" FontSize="26" Foreground="White" Margin="0,0,0,35"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Language Engine -->
                            <Border CornerRadius="18" Background="#1C1C1E" Padding="20" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Zeka &amp; Dil" FontSize="11" Foreground="{StaticResource iosTextSecondary}" FontWeight="Heavy" Margin="0,0,0,20"/>
                                    <StackPanel Margin="0,0,0,15">
                                        <TextBlock Text="OCR Kaynak Dili" Foreground="White" Opacity="0.7" FontSize="13" Margin="0,0,0,8"/>
                                        <ComboBox x:Name="LanguageComboBox" Style="{StaticResource MaterialDesignComboBox}" Foreground="White" SelectionChanged="SettingChanged"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Operational Toggles -->
                            <Border CornerRadius="18" Background="#1C1C1E" Padding="20" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Operasyonel Tercihler" FontSize="11" Foreground="{StaticResource iosTextSecondary}" FontWeight="Heavy" Margin="0,0,0,20"/>
                                    <CheckBox x:Name="TableModeCheckBox" Content="Tablo Düzeni (Markdown)" Foreground="White" Margin="0,8" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <CheckBox x:Name="EnhanceImageCheckBox" Content="Keskinleştirme (Gelişmiş OCR)" Foreground="White" Margin="0,8" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <CheckBox x:Name="AppendModeCheckBox" Content="Taramaları Ardışık Ekle" Foreground="White" Margin="0,8" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <CheckBox x:Name="AutoCopyCheckBox" Content="Sonucu Otomatik Kopyala" Foreground="White" Margin="0,8" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <CheckBox x:Name="AlwaysOnTopCheckBox" Content="Her Zaman Üstte Tut" Foreground="White" Margin="0,8" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <CheckBox x:Name="StartWithWindowsCheckBox" Content="Windows ile Başlat" Foreground="White" Margin="0,8" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                </StackPanel>
                            </Border>

                            <!-- Shortcut Recorder -->
                            <Border CornerRadius="18" Background="#1C1C1E" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Global Kısayol" FontSize="11" Foreground="{StaticResource iosTextSecondary}" FontWeight="Heavy" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="HotkeyTextBlock" Text="Ctrl+Shift+S" Foreground="White" FontSize="15" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <Button Grid.Column="1" Content="Düzenle" Background="#15FFFFFF" Foreground="White" Padding="12,6" Margin="10,0,0,0" BorderThickness="0" Click="ChangeHotkey_Click" materialDesign:ButtonAssist.CornerRadius="10"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Row="2" Content="Değişiklikleri Uygula" Style="{StaticResource iosPillButton}" Height="55" Click="CloseDrawer_Click" Margin="0,20,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Hotkey Recorder -->
        <Grid Grid.ColumnSpan="2" x:Name="HotkeyOverlay" Visibility="Collapsed" Background="#D9000000" PreviewKeyDown="HotkeyOverlay_PreviewKeyDown" Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="KeyboardOutline" Width="60" Height="60" Foreground="{StaticResource iosBlue}" HorizontalAlignment="Center" Margin="0,0,0,25"/>
                <TextBlock Text="YENİ KISAYOL TUŞLAMASI" FontSize="20" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Kaydetmek istediğiniz tuş kombinasyonuna basın..." FontSize="14" Foreground="{StaticResource iosTextSecondary}" Margin="0,15,0,30" HorizontalAlignment="Center"/>
                <Button Content="İptal Et" Click="CancelHotkey_Click" Background="Transparent" Foreground="{StaticResource iosRed}" FontWeight="Bold" FontSize="14" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
