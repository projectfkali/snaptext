<Window x:Class="SnapText.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="SnapText" Height="520" Width="420"
        Background="Transparent"
        Foreground="{DynamicResource MaterialDesignBody}"
        WindowStyle="None" ResizeMode="NoResize"
        Icon="Assets/logo.png"
        AllowsTransparency="True" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Modern Palet & Gradyanlar -->
        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#6366f1" Offset="0"/>
            <GradientStop Color="#a855f7" Offset="1"/>
        </LinearGradientBrush>
        
        <SolidColorBrush x:Key="GlassBackground" Color="#E6111827"/> <!-- Dark Glass -->
        <SolidColorBrush x:Key="CardBackground" Color="#22FFFFFF"/> <!-- White Glass -->
        
        <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="40"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33FFFFFF"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="60" GlassFrameThickness="0" CornerRadius="20" />
    </shell:WindowChrome.WindowChrome>

    <materialDesign:DrawerHost x:Name="MainDrawerHost" BorderThickness="0" BorderBrush="Transparent">
        <!-- RİGHT DRAWER (Geçmiş & Ayarlar) -->
        <materialDesign:DrawerHost.RightDrawerContent>
            <Grid Width="340" Background="#0f172a">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <materialDesign:ColorZone Mode="PrimaryMid" Background="{StaticResource PrimaryGradient}" Padding="20">
                    <TextBlock Text="KONTROL MERKEZİ" FontWeight="Bold" FontSize="16"/>
                </materialDesign:ColorZone>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="OCR GEÇMİŞİ" Opacity="0.5" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ListBox x:Name="HistoryListBox" Background="Transparent" BorderThickness="0" MaxHeight="250">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Card Margin="0,0,0,10" Padding="12" UniformCornerRadius="10" Background="#1e293b">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Text}" MaxWidth="240" TextTrimming="CharacterEllipsis" FontSize="13" Foreground="#f1f5f9"/>
                                                <TextBlock Text="{Binding Timestamp, StringFormat='dd MMM, HH:mm'}" FontSize="10" Opacity="0.4" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Style="{StaticResource ToolButton}" Width="30" Height="30" 
                                                    Click="CopyHistoryItem_Click" Tag="{Binding Text}">
                                                <materialDesign:PackIcon Kind="ContentCopy" Width="14"/>
                                            </Button>
                                        </Grid>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="GEÇMİŞİ TEMİZLE" Margin="0,10,0,20" Click="ClearHistory_Click" 
                                Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="#334155" Foreground="#94a3b8"/>
                        
                        <Separator Background="#1e293b" Margin="0,5,0,20"/>
                        
                        <TextBlock Text="AYARLAR" Opacity="0.5" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <CheckBox x:Name="AutoCopyCheckBox" Content="Metni Otomatik Kopyala" IsChecked="True" Margin="0,0,0,10" Checked="SettingChanged" Unchecked="SettingChanged"/>
                        <CheckBox x:Name="AlwaysOnTopCheckBox" Content="Her Zaman Üstte" IsChecked="False" Margin="0,0,0,10" Checked="SettingChanged" Unchecked="SettingChanged"/>
                        <CheckBox x:Name="StartWithWindowsCheckBox" Content="Windows ile Başlat" Margin="0,0,0,15" Checked="SettingChanged" Unchecked="SettingChanged"/>
                        
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="OCR Okuma Dili" Opacity="0.6" FontSize="11" Margin="0,0,0,5"/>
                            <ComboBox x:Name="LanguageComboBox" Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderThickness="1" BorderBrush="#334155" 
                                      SelectionChanged="SettingChanged" materialDesign:ColorZoneAssist.Mode="SecondaryMid"/>
                        </StackPanel>

                        <StackPanel Margin="0,15,0,0">
                            <TextBlock Text="Hedef Çeviri Dili" Opacity="0.6" FontSize="11" Margin="0,0,0,5"/>
                            <ComboBox x:Name="TargetLangComboBox" Style="{StaticResource MaterialDesignOutlinedComboBox}" SelectionChanged="SettingChanged">
                                <ComboBoxItem Content="Türkçe" Tag="tr"/>
                                <ComboBoxItem Content="İngilizce" Tag="en"/>
                                <ComboBoxItem Content="Almanca" Tag="de"/>
                                <ComboBoxItem Content="Fransızca" Tag="fr"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2" Content="MENÜYÜ KAPAT" Margin="20" Click="CloseDrawer_Click" 
                        Style="{StaticResource MaterialDesignFlatMidBgButton}"/>
            </Grid>
        </materialDesign:DrawerHost.RightDrawerContent>

        <!-- MAIN INTERFACE -->
        <Border CornerRadius="20" Background="{StaticResource GlassBackground}" BorderBrush="#33FFFFFF" BorderThickness="1" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Custom Title Bar -->
                <Grid Height="60">
                    <StackPanel Orientation="Horizontal" Margin="20,0">
                        <Border Width="32" Height="32" CornerRadius="8" Background="{StaticResource PrimaryGradient}" Margin="0,0,12,0">
                            <materialDesign:PackIcon Kind="AutoFix" Foreground="White" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="SNAPTEXT" FontSize="18" FontWeight="ExtraBold" VerticalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0">
                        <Button Style="{StaticResource ToolButton}" Click="OpenDrawer_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <materialDesign:PackIcon Kind="Settings" Width="20" Height="20"/>
                        </Button>
                        <Button Style="{StaticResource ToolButton}" Click="CloseButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Foreground="#f43f5e">
                            <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Result Area -->
                <Grid Grid.Row="1" Margin="25,5,25,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card UniformCornerRadius="15" Background="#15FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1" Padding="5">
                        <TextBox x:Name="ResultTextBox" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 FontSize="14" Foreground="#f8fafc" IsReadOnly="False" BorderThickness="0"
                                 materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                 Text="SnapText hazır. Hadi bir şeyler yakalayalım!"/>
                    </materialDesign:Card>

                    <!-- Floating Action Bar -->
                    <Border Grid.Row="1" Margin="0,-25,0,0" Background="#CC1e293b" CornerRadius="25" Padding="5" 
                            HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="50" BorderBrush="#40FFFFFF" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource ToolButton}" Click="CopyCurrent_Click" ToolTip="Kopyala">
                                <materialDesign:PackIcon Kind="ContentCopy" Width="18"/>
                            </Button>
                            <Button Style="{StaticResource ToolButton}" Click="SearchGoogle_Click" ToolTip="Google'da Ara">
                                <materialDesign:PackIcon Kind="Google" Width="18"/>
                            </Button>
                            <Button Style="{StaticResource ToolButton}" Click="Translate_Click" ToolTip="Tercüme Et">
                                <materialDesign:PackIcon Kind="Translate" Width="18"/>
                            </Button>
                            <Button Style="{StaticResource ToolButton}" Click="Speak_Click" ToolTip="Dinle">
                                <materialDesign:PackIcon Kind="VolumeHigh" Width="18"/>
                            </Button>
                            <Separator Background="#33FFFFFF" Width="1" Margin="5,10"/>
                            <Button Style="{StaticResource ToolButton}" Click="ClearCurrent_Click" ToolTip="Temizle" Foreground="#fb7185">
                                <materialDesign:PackIcon Kind="Delete" Width="18"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Action Button -->
                <Grid Grid.Row="2" Margin="30,10,30,30">
                    <Button Content="EKRAN YAKALA" Height="55" 
                            FontSize="15" FontWeight="ExtraBold"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource PrimaryGradient}"
                            BorderThickness="0"
                            materialDesign:ButtonAssist.CornerRadius="14"
                            Click="CaptureButton_Click">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="15" Color="#6366f1" Opacity="0.4" ShadowDepth="0"/>
                        </Button.Effect>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </materialDesign:DrawerHost>
</Window>
