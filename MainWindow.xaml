<Window x:Class="SnapText.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="SnapText" Height="500" Width="400"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        WindowStyle="None" ResizeMode="NoResize"
        Icon="Assets/logo.png"
        AllowsTransparency="True" WindowStartupLocation="CenterScreen">
    
    <materialDesign:DrawerHost x:Name="MainDrawerHost" BorderThickness="0" BorderBrush="Transparent">
        <!-- RİGHT DRAWER (Settings & History) -->
        <materialDesign:DrawerHost.RightDrawerContent>
            <Grid Width="320" Background="#18181b">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <materialDesign:ColorZone Mode="PrimaryMid" Padding="16">
                    <TextBlock Text="GEÇMİŞ VE AYARLAR" FontWeight="Bold"/>
                </materialDesign:ColorZone>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="OCR GEÇMİŞİ" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,10" FontSize="14" Opacity="0.6"/>
                        <ListBox x:Name="HistoryListBox" Background="Transparent" BorderThickness="0" MaxHeight="250">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Card Margin="0,0,0,8" Padding="10" Background="#242427">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Text}" MaxWidth="220" TextTrimming="CharacterEllipsis" FontSize="12"/>
                                                <TextBlock Text="{Binding Timestamp, StringFormat='dd/MM HH:mm'}" FontSize="10" Opacity="0.5"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Style="{StaticResource MaterialDesignFlatButton}" 
                                                    Padding="0" Width="30" Height="30" Click="CopyHistoryItem_Click" Tag="{Binding Text}">
                                                <materialDesign:PackIcon Kind="ContentCopy" Width="16"/>
                                            </Button>
                                        </Grid>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Separator Margin="0,15" Background="#333333"/>
                        
                        <TextBlock Text="SİSTEM AYARLARI" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,10" FontSize="14" Opacity="0.6"/>
                        
                        <CheckBox x:Name="AutoCopyCheckBox" Content="Metni Otomatik Kopyala" IsChecked="True" Margin="0,0,0,10" Checked="SettingChanged" Unchecked="SettingChanged"/>
                        <CheckBox x:Name="AlwaysOnTopCheckBox" Content="Her Zaman Üstte Kalsın" IsChecked="False" Margin="0,0,0,10" Checked="SettingChanged" Unchecked="SettingChanged"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Okuma Dili:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="LanguageComboBox" Width="150" SelectionChanged="SettingChanged">
                                <ComboBoxItem Content="Türkçe" Tag="tr-TR"/>
                                <ComboBoxItem Content="İngilizce" Tag="en-US"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2" Content="MENÜYÜ KAPAT" Margin="16" Click="CloseDrawer_Click" Style="{StaticResource MaterialDesignFlatButton}"/>
            </Grid>
        </materialDesign:DrawerHost.RightDrawerContent>

        <!-- MAIN CONTENT -->
        <materialDesign:Card UniformCornerRadius="14" Margin="5" Background="#121212" BorderBrush="#2a2a2a" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <materialDesign:ColorZone Mode="PrimaryMid" Padding="14">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="Assets/logo.png" Width="24" Height="24" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="SNAPTEXT V3" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Width="40" Padding="0" Height="40" Click="OpenDrawer_Click">
                                <materialDesign:PackIcon Kind="Settings" Width="20" Height="20"/>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Width="30" Padding="0" Height="30" Click="CloseButton_Click" Content="✕"/>
                        </StackPanel>
                    </Grid>
                </materialDesign:ColorZone>

                <StackPanel Grid.Row="1" Margin="20">
                    <Grid>
                        <TextBlock Text="Okunan Metin" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.6" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Padding="4" Height="25" Click="CopyCurrent_Click" ToolTip="Kopyala">
                                <materialDesign:PackIcon Kind="ContentCopy" Width="14"/>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Padding="4" Height="25" Click="ClearCurrent_Click" ToolTip="Temizle">
                                <materialDesign:PackIcon Kind="Delete" Width="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    
                    <materialDesign:Card Background="#000000" BorderBrush="#333333" BorderThickness="1" Padding="10">
                        <TextBox x:Name="ResultTextBox" Height="240" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 FontSize="14" Foreground="#fafafa" IsReadOnly="False" BorderThickness="0"
                                 materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                 Text="SnapText V3 hazır!"/>
                    </materialDesign:Card>
                </StackPanel>

                <Grid Grid.Row="2" Margin="20,0,20,20">
                    <Button Content="EKRANDAN YAZI ÇIKAR" Height="50" 
                            FontSize="14" FontWeight="Bold"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="10"
                            Click="CaptureButton_Click"/>
                </Grid>
            </Grid>
        </materialDesign:Card>
    </materialDesign:DrawerHost>
</Window>
