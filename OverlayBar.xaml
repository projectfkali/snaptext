<Window x:Class="SnapText.OverlayBar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Overlay" Height="60" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False">
    
    <Window.Resources>
        <Style x:Key="PremiumAiButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10" Margin="3,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#2C2C2E" CornerRadius="16" Opacity="0.95" Padding="5,5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="4"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            
            <Button Style="{StaticResource iosIconButton}" Click="Copy_Click" ToolTip="Kopyala" Width="36" Height="36">
                <materialDesign:PackIcon Kind="ContentCopy" Width="18"/>
            </Button>
            
            <Button Style="{StaticResource iosIconButton}" Click="TranslateWeb_Click" ToolTip="Web'de Çevir" Width="36" Height="36">
                <materialDesign:PackIcon Kind="Web" Width="18"/>
            </Button>

            <Rectangle Width="1" Fill="#38383A" Margin="8,8" VerticalAlignment="Stretch"/>

            <Button Style="{StaticResource PremiumAiButton}" Foreground="#0A84FF" Click="AiTranslate_Click">
                <StackPanel Orientation="Horizontal" Margin="6,0">
                    <materialDesign:PackIcon Kind="Translate" Width="16" Height="16" VerticalAlignment="Center"/>
                    <TextBlock Text="AI Çevir" FontWeight="Bold" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource PremiumAiButton}" Foreground="#BF5AF2" Click="AiSummarize_Click">
                <StackPanel Orientation="Horizontal" Margin="6,0">
                    <materialDesign:PackIcon Kind="Creation" Width="16" Height="16" VerticalAlignment="Center"/>
                    <TextBlock Text="Özetle" FontWeight="Bold" FontSize="12" Margin="4,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Rectangle Width="1" Fill="#38383A" Margin="8,8" VerticalAlignment="Stretch"/>
            
            <Button Style="{StaticResource iosIconButton}" Click="Close_Click" Foreground="#FF453A" Width="36" Height="36">
                <materialDesign:PackIcon Kind="Close" Width="18"/>
            </Button>
            
        </StackPanel>
    </Border>
</Window>
