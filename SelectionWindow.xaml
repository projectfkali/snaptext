<Window x:Class="SnapText.SelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Seçim Alanı" WindowStyle="None" Topmost="True" 
        AllowsTransparency="True" Background="#01000000" Cursor="Cross"
        WindowState="Maximized" MouseDown="Window_MouseDown" 
        MouseMove="Window_MouseMove" MouseUp="Window_MouseUp">
    <Grid x:Name="RootGrid">
        <Path Fill="#80000000">
            <Path.Data>
                <GeometryGroup FillRule="EvenOdd">
                    <!-- Tam ekran kapatan parça -->
                    <RectangleGeometry x:Name="FullScreenGeometry" />
                    <!-- Seçim alanı (delik açılacak kısım) -->
                    <RectangleGeometry x:Name="SelectionGeometry" />
                </GeometryGroup>
            </Path.Data>
        </Path>

        <Canvas x:Name="OverlayCanvas">
            <!-- Seçim çerçevesi (mavi dış hat) -->
            <Rectangle x:Name="SelectionRectangle" Stroke="#0A84FF" StrokeThickness="2" Visibility="Hidden" />
            
            <!-- Floating Toolbar (Lightshot benzeri) -->
            <Border x:Name="FloatingToolbar" Visibility="Collapsed" Background="#2C2C2E" CornerRadius="10" Padding="6,4" HorizontalAlignment="Left" VerticalAlignment="Top" BorderBrush="#3A3A3C" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.6" ShadowDepth="4"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource iosIconButton}" Click="ActionCopy_Click" ToolTip="Panoya Kopyala" Foreground="#EBEBF5">
                        <materialDesign:PackIcon Kind="ContentCopy" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource iosIconButton}" Click="ActionTranslate_Click" ToolTip="Web'de Çevir" Foreground="#EBEBF5">
                        <materialDesign:PackIcon Kind="Translate" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource iosIconButton}" Click="ActionGoogle_Click" ToolTip="Google'da Ara" Foreground="#EBEBF5">
                        <materialDesign:PackIcon Kind="Google" Width="18" Height="18"/>
                    </Button>
                    <Rectangle Width="1" Fill="#48484A" Margin="6,6"/>
                    <Button Style="{StaticResource iosIconButton}" Click="ActionClose_Click" ToolTip="Çıkış" Foreground="#FF453A">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                    </Button>
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>
